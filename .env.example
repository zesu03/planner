VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Server-only, used by api/gemini-report.js ──────────────────────────────
# These power the daily AI reflection. They are NOT prefixed with VITE_ so
# they stay off the client bundle. Set them in Vercel project → Settings →
# Environment Variables.

# Google AI Studio API key (https://aistudio.google.com/app/apikey).
# IMPORTANT: never paste this into version control or chat — rotate if leaked.
GEMINI_API_KEY=

# Optional. Defaults to "gemini-2.5-flash".
GEMINI_MODEL=gemini-2.5-flash

# Base64-encoded Firebase service account JSON. Used to verify the caller's
# Firebase ID token before forwarding to Gemini, so randos can't burn quota.
# Generate: Firebase Console → Project Settings → Service accounts → Generate
# new private key. Then base64 the JSON:
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("svc.json"))
#   bash/macOS: base64 -i svc.json
FIREBASE_SERVICE_ACCOUNT=